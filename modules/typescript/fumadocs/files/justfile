# Task runner for this Fumadocs (TanStack Start + Vite) documentation site.
# Tools (bun, oxlint, oxfmt, tsc) are provided by the Nix dev shell (nix-bun-flake).
# Node-shebang bins (vite, fumadocs-mdx) run under Bun: `bun run` aliases node -> bun.

# List available recipes
default:
    @just --list

# Install dependencies with Bun (runs the fumadocs-mdx postinstall)
install:
    bun install

# Start the dev server (http://localhost:3000); copies fonts first
dev:
    bun run dev

# Build the static site into .output/public
build:
    bun run build

# Generate the MDX source map, then type-check without emitting
typecheck:
    bun run typecheck

# Format sources in place (strips semicolons, sorts imports)
format:
    oxfmt --write .

# Verify formatting without writing (CI mode)
format-check:
    oxfmt --check .

# Lint sources with oxlint
lint:
    oxlint

# Lint and auto-fix where possible
lint-fix:
    oxlint --fix

# Check internal/external links in the built site
lint-links:
    bun run lint:links

# Run all checks: typecheck, lint, formatting, and a production build
check: typecheck lint format-check build
